{
	"$schema": "node_modules/wrangler/config-schema.json",
  "name": "almosterm",
  "main": "worker/index.ts",
  "compatibility_date": "2025-07-17",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "assets": {
    // Served by the Worker; built by @cloudflare/vite-plugin
    "directory": "dist"
  },
  "observability": {
    "enabled": true
  }
}
